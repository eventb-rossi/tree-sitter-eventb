{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "eventb",
      "camelcase": "EventB",
      "scope": "source.eventb",
      "path": ".",
      "file-types": [
        "eventb"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^eventb$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT OR Apache-2.0",
    "description": "Event-B lexical grammar for tree-sitter (Rossi)",
    "authors": [
      {
        "name": "Rossi Contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/eventb-rossi/tree-sitter-eventb"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
